# chip production environment — copy to `.env` and fill in.
#   cp .env.production.example .env  &&  edit .env
# Generate secrets with: openssl rand -hex 32

# --- Postgres (container) ---------------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
# If you use Amazon RDS instead, point DATABASE_URL at it and delete the
# postgres service from docker-compose.prod.yml.
DATABASE_URL=postgres://chip:CHANGE_ME_strong_db_password@postgres:5432/chip

# --- Required secrets -------------------------------------------------------
# CSRF / session secret.
CHIP_SECRET=CHANGE_ME_openssl_rand_hex_32
# Encryption-at-rest key (64 hex / 32 bytes). *** BACK THIS UP OFFLINE ***
# Losing it makes every stored repository permanently unrecoverable.
CHIP_DATA_KEY=CHANGE_ME_openssl_rand_hex_32

# --- Public identity --------------------------------------------------------
# Your domain; must be https for Secure cookies + correct UI links.
CHIP_BASE_URL=https://chip.example.com

# --- Object storage ---------------------------------------------------------
# Filesystem on the data volume (simplest):
CHIP_OBJECT_STORE=local:///data/repos
# OR S3 (recommended at scale) — set the bucket and provide credentials via an
# EC2 instance IAM role (preferred) or AWS_* vars:
# CHIP_OBJECT_STORE=s3://my-chip-objects
# AWS_REGION=us-east-1

# --- TLS (native, ALPN h2 + http/1.1 on one port) ---------------------------
# Your cert domain — used to mount /etc/letsencrypt/live/<domain> into the
# container (see docker-compose.prod.yml).
CERT_DOMAIN=chip.example.com
# Paths *inside the container* (the mount above maps the host cert dir to /certs).
CHIP_TLS_CERT=/certs/fullchain.pem
CHIP_TLS_KEY=/certs/privkey.pem

# --- SSH transport ----------------------------------------------------------
CHIP_SSH_BIND=0.0.0.0:2222
CHIP_SSH_HOST_KEY=/data/ssh_host_ed25519

# --- Tuning (optional) ------------------------------------------------------
CHIP_DB_MAX_CONNECTIONS=25
